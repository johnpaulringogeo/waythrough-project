{#- Housing-authority page template (bilingual EN/ES). Renders one authority from
    data/authorities/<slug>.json for a given language. The caller (generate_authority.py)
    passes fully-built, language-specific strings so the template stays a thin shell.
    Context: data, lang, t, title, description, canonical_path, alt_en_url, alt_es_url,
    rel_prefix, home_href, resources_href, breadcrumb_json, gov_json, faq_json -#}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YQ0HKFH50D"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQ0HKFH50D');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="{{ rel_prefix }}images/favicon.png">
    <link rel="icon" type="image/x-icon" href="{{ rel_prefix }}images/favicon.ico">
    <link rel="apple-touch-icon" href="{{ rel_prefix }}images/apple-touch-icon.png">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://waythroughproject.com{{ canonical_path }}">
    <meta property="og:site_name" content="Waythrough Project">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="canonical" href="https://waythroughproject.com{{ canonical_path }}">
    <link rel="alternate" hreflang="en" href="{{ alt_en_url }}">
    <link rel="alternate" hreflang="es" href="{{ alt_es_url }}">
    <link rel="alternate" hreflang="x-default" href="{{ alt_en_url }}">
    <meta property="og:image" content="https://waythroughproject.com/images/og-default.png">
    <meta name="twitter:image" content="https://waythroughproject.com/images/og-default.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet"></noscript>
    <script>(function(){try{var t=localStorage.getItem('theme');if(!t){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
    <link rel="stylesheet" href="{{ rel_prefix }}css/style.css?v=31">
    <script type="application/ld+json">
{{ breadcrumb_json }}
    </script>
    <script type="application/ld+json">
{{ gov_json }}
    </script>
    {%- if data.faqs %}
    <script type="application/ld+json">
{{ faq_json }}
    </script>
    {%- endif %}
</head>
<body>
    <main id="main-content">
        <nav class="breadcrumbs" aria-label="Breadcrumb"><div class="container"><a href="{{ home_href }}">{{ t.home }}</a><span class="sep">/</span><a href="{{ resources_href }}">{{ t.resources }}</a><span class="sep">/</span><a href="./">{{ t.authorities }}</a><span class="sep">/</span><span class="current">{{ data.short_name or data.name }}</span></div></nav>
        <header class="page-header">
            <div class="container">
                <span class="section-label">{{ t.section_label }}</span>
                <h1>{{ data.name }}</h1>
                <p class="page-meta">{{ t.page_meta }}</p>
            </div>
        </header>
        <div class="container">
            <div class="post-content">
                <div class="callout">
                    <p>{{ t.independent_html }}</p>
                </div>

                <p>{{ data.intro }}</p>

                <div class="callout">
                    <h2 style="font-size:1.1rem;margin-top:0;">{{ t.quick_facts }}</h2>
                    <p>{{ t.quick_facts_html }}</p>
                </div>

                <h2>{{ t.waitlist_status }}</h2>
                <p>{{ t.waitlist_intro }}</p>
                <ul>
                    {%- for w in data.waitlists %}
                    <li><strong>{{ w.program }}:</strong> {{ w.status }}{% if w.note %} — {{ w.note }}{% endif %}</li>
                    {%- endfor %}
                </ul>

                <h2>{{ t.programs_heading }}</h2>
                <ul>
                    {%- for p in data.programs %}
                    <li>{{ p }}</li>
                    {%- endfor %}
                </ul>

                <h2>{{ t.how_to_apply }}</h2>
                <p>{{ t.apply_body_html }}</p>
                <p>{{ t.new_to_process_html }}</p>

                {%- if data.also_serving %}
                <h2>{{ t.other_authorities }}</h2>
                <ul>
                    {%- for a in data.also_serving %}
                    <li>{{ a }}</li>
                    {%- endfor %}
                </ul>
                {%- endif %}

                <h2>{{ t.more_local_heading }}</h2>
                <p>{{ t.more_local_html }}</p>

                {%- if data.faqs %}
                <h2>{{ t.faq_heading }}</h2>
                {%- for f in data.faqs %}
                <h3>{{ f.q }}</h3>
                <p>{{ f.a }}</p>
                {%- endfor %}
                {%- endif %}

                {%- if data.sources %}
                <h2>{{ t.sources }}</h2>
                <ul>
                    {%- for s in data.sources %}
                    <li><a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.label }}</a></li>
                    {%- endfor %}
                </ul>
                {%- endif %}
            </div>
        </div>
    </main>

    <script src="{{ rel_prefix }}js/components.js?v=31" defer></script>
</body>
</html>
